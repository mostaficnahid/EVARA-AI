# ── Vercel Environment Variables ──────────────────────────────────────────
# Add ALL of these in: Vercel Dashboard → Your Project → Settings → Environment Variables
# Set scope to: Production + Preview + Development

# MongoDB Atlas connection string (required)
# Create a free cluster at https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/evara-ai?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your-user:your-password@cluster0.xxxxx.mongodb.net/evara-ai?retryWrites=true&w=majority

# JWT signing secret — use a long random string (required)
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-string-in-production

JWT_EXPIRES_IN=7d

# Anthropic API key (required for all AI features)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

NODE_ENV=production
