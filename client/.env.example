# On Vercel: set these in Project Settings → Environment Variables
# Locally: copy to .env.local and fill in values

# Leave blank — the client uses relative /api/* paths which Vercel rewrites automatically
# VITE_API_URL=

# Used by the browser-side AI widget (the live preview in this chat)
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key-here
